 restore_neutron = 1)
AT (0, 0, 0.000000001) RELATIVE PS1

COMPONENT PS2 = DiskChopper(
 theta_0 = theta_PS, radius = 0.35,
 yheight = 0.07389, nu = - Freq_PS,
 delay = PS2_Delay, verbose = 1)
WHEN (enable_PS2 == 1)
AT (0, 0, 0.006) RELATIVE TOF_PS

COMPONENT Lambda_PS = L_monitor(
 nL = 1000, filename = "Lambda_PS",
