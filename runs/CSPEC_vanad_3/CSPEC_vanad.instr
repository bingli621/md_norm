 Qc = 0.0219, alpha = 6.07,
 mleft = 3.5, mright = 3.5,
 mtop = 3.5, mbottom = 3.5,
 G = 9.82, reflect = "NULL")
AT (0, 0, 1e-06) RELATIVE Arm85

COMPONENT Arm86 = Arm()
AT (0, 0, 1.5894 + 0.003) RELATIVE Guide_w03_08_26

COMPONENT Guide_w03_09_01 = Guide_gravity(
 w1 = 0.02779, h1 = 0.04991,
 w2 = 0.02258, h2 = 0.04900,
 l = 0.6 -0.1, R0 = 0.99,
 Qc = 0.0219, alpha = 6.07,
 mleft = 3.5, mright = 3.5,
 mtop = 3.5, mbottom = 3.5,
 G = 9.82, reflect = "NULL")
AT (0, 0, 1e-06) RELATIVE Arm86

COMPONENT Arm87_WindowPreMChopper = Arm()
AT (0, 0, 0.51 + 1e-6) RELATIVE Guide_w03_09_01

COMPONENT M0 = DiskChopper(
 theta_0 = theta_M, radius = 0.35,
 yheight = 0.04900, nu = Freq_M/4,
 nslit = 1, delay = M1_Delay,
 verbose = 1)
WHEN (enable_M0 == 1)
AT (0, 0, 0.019) RELATIVE Arm87_WindowPreMChopper

COMPONENT M1 = DiskChopper(
 theta_0 = theta_M, radius = 0.35,
 yheight = 0.04900, nu = Freq_M,
 nslit = 1, delay = M1_Delay,
 verbose = 1)
WHEN (enable_M1 == 1)
AT (0, 0, 0.02) RELATIVE Arm87_WindowPreMChopper

COMPONENT TOF_M = TOF_monitor(
 nt = 1000, filename = "TOF_M",
 tmin = 252.78 * ( lambda_min -0.2 ) * Distance_M1, tmax = 252.78 * ( lambda_min + 0.2 ) * Distance_M1,
 restore_neutron = 1)
AT (0, 0, 0.000000001) RELATIVE M1

COMPONENT M2 = DiskChopper(
 theta_0 = theta_M, radius = 0.35,
 yheight = 0.04900, nu = - Freq_M,
 nslit = 1, delay = M2_Delay,
 verbose = 1)
WHEN (enable_M2 == 1)
AT (0, 0, 0.006) RELATIVE TOF_M

COMPONENT Lambda_M = L_monitor(
 nL = 1000, filename = "Lambda_M",
 Lmin = lambda_min -0.8, Lmax = lambda_min + 0.8,
 restore_neutron = 1)
AT (0, 0, 0.001) RELATIVE M2

COMPONENT Arm88_WindowPostMChopper = Arm()
AT (0, 0, dist_m) RELATIVE Arm87_WindowPreMChopper

COMPONENT Arm89_Windows_Monitor = Arm()
